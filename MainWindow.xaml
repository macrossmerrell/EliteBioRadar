<Window x:Class="EliteBioRadar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elite Bio Radar"
        Height="700" Width="750"
        MinHeight="300" MinWidth="400"
        Background="#0a0f0f"
        SizeChanged="Window_SizeChanged">

    <Window.Resources>
        <Style x:Key="BarLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#88bbbb"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="BarValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#00e5ff"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- Thin scrollbar for sidebars — 6px wide, dark themed -->
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="#0d1a1a"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="#0d1a1a" CornerRadius="3"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#1a4444" CornerRadius="3" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ThinScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1"
                                       Style="{StaticResource ThinScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0" Background="#0d1a1a" BorderBrush="#1a4444"
                BorderThickness="0,0,0,1" Padding="8,6">
            <DockPanel LastChildFill="False">

                <Button x:Name="btnSettings" DockPanel.Dock="Right"
                        Width="30" Height="30"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Padding="0" VerticalAlignment="Center"
                        Click="BtnSettings_Click">
                    <Viewbox Width="20" Height="20">
                        <Canvas Width="24" Height="24">
                            <Path Fill="#00e5ff" Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63Z"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <WrapPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal" Margin="0,2,14,2">
                        <TextBlock Text="BODY: " Style="{StaticResource BarLabel}"/>
                        <TextBlock x:Name="txtBodyName" Text="—" Style="{StaticResource BarValue}" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,14,2">
                        <TextBlock Text="BIO: " Style="{StaticResource BarLabel}"/>
                        <TextBlock x:Name="txtBioScanned" Text="0" Style="{StaticResource BarValue}"/>
                        <TextBlock Text="/" Style="{StaticResource BarLabel}"/>
                        <TextBlock x:Name="txtBioCount" Text="0" Style="{StaticResource BarValue}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,14,2">
                        <TextBlock Text="SCALE: " Style="{StaticResource BarLabel}"/>
                        <TextBlock x:Name="txtScale" Text="1000m" Style="{StaticResource BarValue}"/>
                        <TextBlock Text=" [scroll]" Style="{StaticResource BarLabel}" Foreground="#335555" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,14,2">
                        <TextBlock Text="POTENTIAL: " Style="{StaticResource BarLabel}"/>
                        <TextBlock x:Name="txtPotentialPayout" Text="—" Style="{StaticResource BarValue}"/>
                    </StackPanel>
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="planetCol" Width="0"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="sidebarCol" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- PLANET LIST PANEL (left) -->
            <Border x:Name="planetPanel" Grid.Column="0"
                    Background="#0d1a1a" BorderBrush="#1a4444"
                    BorderThickness="0,0,1,0" Padding="8"
                    Visibility="Collapsed">
                <ScrollViewer Style="{StaticResource ThinScrollViewer}">
                    <StackPanel x:Name="planetStack"/>
                </ScrollViewer>
            </Border>

            <!-- PLANET TOGGLE BUTTON — always at left edge of radar column -->
            <Button x:Name="btnPlanetPanel"
                    Grid.Column="1"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Width="26" Height="26" Margin="4,4,0,0"
                    Background="#0d1a1a" BorderBrush="#1a4444"
                    BorderThickness="1" Padding="0"
                    Cursor="Hand" Panel.ZIndex="10"
                    Click="BtnPlanetPanel_Click"
                    ToolTip="Planets with Biology">
                <Viewbox Width="16" Height="16">
                    <Canvas Width="24" Height="24">
                        <Path x:Name="planetBtnIcon" Fill="#00e5ff"
                              Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4C14.21,4 16.21,4.86 17.71,6.29C16.32,6.28 14.44,6.93 13.07,8.35C11.69,9.77 11.09,11.66 11.12,13.05C9.7,14.42 8.04,14.31 6.62,13.77C5.57,13.37 4.67,12.67 4.18,12.03C5.17,7.54 8.62,4 12,4M20,12C20,12.23 19.99,12.46 19.97,12.68C19.44,12.42 18.75,12.29 17.95,12.38C17.14,12.47 16.45,12.81 15.97,13.28C15.27,13.95 14.97,14.86 15.08,15.76C15.19,16.71 15.72,17.55 16.43,18.07C15.16,19.27 13.67,20 12,20C9.79,20 7.79,19.14 6.29,17.71L6.53,17.65C7.96,17.3 9.53,16.56 10.63,15.15C11.62,15.3 12.73,15.06 13.73,14.36C14.7,13.69 15.32,12.7 15.49,11.65C16.28,10.36 17.59,9.71 18.87,9.77C19.58,10.46 20,11.18 20,12Z"/>
                    </Canvas>
                </Viewbox>
            </Button>

            <Canvas x:Name="radarCanvas" Grid.Column="1"
                    Background="#080d0d" ClipToBounds="True"
                    MouseWheel="RadarCanvas_MouseWheel"/>

            <Border x:Name="sidebarPanel" Grid.Column="2"
                    Background="#0d1a1a" BorderBrush="#1a4444"
                    BorderThickness="1,0,0,0" Padding="8"
                    Visibility="Collapsed">
                <ScrollViewer Style="{StaticResource ThinScrollViewer}">
                    <StackPanel x:Name="sidebarStack"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- BOTTOM BAR -->
        <Border Grid.Row="2" Background="#0d1a1a" BorderBrush="#1a4444"
                BorderThickness="0,1,0,0" Padding="8,6">
            <WrapPanel Orientation="Horizontal">
                <StackPanel Orientation="Horizontal" Margin="0,2,14,2">
                    <TextBlock Text="LAT: " Style="{StaticResource BarLabel}"/>
                    <TextBlock x:Name="txtLat" Text="—" Style="{StaticResource BarValue}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,14,2">
                    <TextBlock Text="LON: " Style="{StaticResource BarLabel}"/>
                    <TextBlock x:Name="txtLon" Text="—" Style="{StaticResource BarValue}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,14,2">
                    <TextBlock Text="HDG: " Style="{StaticResource BarLabel}"/>
                    <TextBlock x:Name="txtHeading" Text="—°" Style="{StaticResource BarValue}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,14,2">
                    <TextBlock Text="ALT: " Style="{StaticResource BarLabel}"/>
                    <TextBlock x:Name="txtAlt" Text="—" Style="{StaticResource BarValue}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,14,2">
                    <TextBlock Text="NEAREST: " Style="{StaticResource BarLabel}"/>
                    <TextBlock x:Name="txtScanOne" Text="—" Style="{StaticResource BarValue}"/>
                </StackPanel>
                <!-- Scan pips -->
                <StackPanel Orientation="Horizontal" Margin="0,2,12,2" VerticalAlignment="Center">
                    <Border x:Name="pip1Border" Width="16" Height="16" CornerRadius="8"
                            BorderBrush="#224455" BorderThickness="2" Margin="2,0"
                            Background="#000811" VerticalAlignment="Center">
                        <Ellipse x:Name="pip1Fill" Width="7" Height="7"
                                 Fill="#000811" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="pip2Border" Width="16" Height="16" CornerRadius="8"
                            BorderBrush="#225544" BorderThickness="2" Margin="2,0"
                            Background="#081108" VerticalAlignment="Center">
                        <Ellipse x:Name="pip2Fill" Width="7" Height="7"
                                 Fill="#081108" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="pip3Border" Width="16" Height="16" CornerRadius="8"
                            BorderBrush="#554422" BorderThickness="2" Margin="2,0"
                            Background="#110800" VerticalAlignment="Center">
                        <Ellipse x:Name="pip3Fill" Width="7" Height="7"
                                 Fill="#110800" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                    <TextBlock Text="EARNED: " Style="{StaticResource BarLabel}"/>
                    <TextBlock x:Name="txtSessionEarned" Text="—" Style="{StaticResource BarValue}"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- SETTINGS POPUP -->
        <Border x:Name="settingsPanel" Grid.Row="0" Grid.RowSpan="3"
                Background="#EE0d1a1a" BorderBrush="#1a4444" BorderThickness="1"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,38,0,0" Padding="14" Width="280"
                Visibility="Collapsed">
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="SETTINGS" Foreground="#00e5ff" FontFamily="Consolas"
                               FontSize="14" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <Button Content="About" DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            Background="#1a3333" Foreground="#44aaaa"
                            FontFamily="Consolas" FontSize="12"
                            BorderBrush="#1a4444" Padding="6,2"
                            Click="BtnAbout_Click"/>
                </DockPanel>

                <CheckBox x:Name="chkSidebar" Foreground="#00e5ff" FontFamily="Consolas"
                          FontSize="13" Margin="0,5"
                          Checked="ChkSidebar_Changed" Unchecked="ChkSidebar_Changed">
                    Show Bio Survey Sidebar
                </CheckBox>

                <CheckBox x:Name="chkPlanetOverlay" Foreground="#00e5ff" FontFamily="Consolas"
                          FontSize="13" Margin="0,5"
                          Checked="ChkPlanetOverlay_Changed" Unchecked="ChkPlanetOverlay_Changed">
                    Planet Panel overlays radar
                </CheckBox>
                <TextBlock Text="  When unchecked, panel shrinks the radar"
                           Foreground="#446666" FontFamily="Consolas" FontSize="11"
                           Margin="0,0,0,4" TextWrapping="Wrap"/>

                <CheckBox x:Name="chkKeepPlanetOpen" Foreground="#00e5ff" FontFamily="Consolas"
                          FontSize="13" Margin="0,5"
                          Checked="ChkKeepPlanetOpen_Changed" Unchecked="ChkKeepPlanetOpen_Changed">
                    Keep Bio Sites panel open
                </CheckBox>
                <TextBlock Text="  Panel stays open between sessions"
                           Foreground="#446666" FontFamily="Consolas" FontSize="11"
                           Margin="0,0,0,8" TextWrapping="Wrap"/>

                <CheckBox x:Name="chkAutoScale" Foreground="#00e5ff" FontFamily="Consolas"
                          FontSize="13" Margin="0,5"
                          Checked="ChkAutoScale_Changed" Unchecked="ChkAutoScale_Changed">
                    Auto Scale
                </CheckBox>
                <TextBlock Text="  Expands view to keep all organisms visible"
                           Foreground="#446666" FontFamily="Consolas" FontSize="11"
                           Margin="0,0,0,8" TextWrapping="Wrap"/>

                <TextBlock Text="Default Scale:" Foreground="#88bbbb"
                           FontFamily="Consolas" FontSize="13" Margin="0,6,0,4"/>
                <ComboBox x:Name="cmbDefaultScale"
                          Background="#0d2020" Foreground="#000000"
                          FontFamily="Consolas" FontSize="13" Width="110"
                          HorizontalAlignment="Left"
                          SelectionChanged="CmbDefaultScale_Changed">
                    <ComboBoxItem Tag="200">200m</ComboBoxItem>
                    <ComboBoxItem Tag="500">500m</ComboBoxItem>
                    <ComboBoxItem Tag="1000" IsSelected="True">1000m</ComboBoxItem>
                    <ComboBoxItem Tag="2000">2000m</ComboBoxItem>
                    <ComboBoxItem Tag="5000">5000m</ComboBoxItem>
                    <ComboBoxItem Tag="10000">10000m</ComboBoxItem>
                </ComboBox>

                <TextBlock Text="─────────────────" Foreground="#1a4444"
                           FontFamily="Consolas" FontSize="10" Margin="0,10,0,6"/>

                <TextBlock Text="Earnings" Foreground="#00e5ff" FontFamily="Consolas"
                           FontSize="13" FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBlock x:Name="txtTotalEarned" Text="Total: —"
                           Foreground="#88bbbb" FontFamily="Consolas" FontSize="12" Margin="0,0,0,8"/>

                <Button x:Name="btnScanJournals" Content="Scan All Journals"
                        Margin="0,4,0,0"
                        Background="#1a3333" Foreground="#00e5ff"
                        FontFamily="Consolas" FontSize="12"
                        BorderBrush="#1a4444" Padding="8,4"
                        HorizontalAlignment="Left"
                        Click="BtnScanJournals_Click"/>

                <TextBlock Text="  — or scan a date range —"
                           Foreground="#446666" FontFamily="Consolas" FontSize="10"
                           Margin="0,6,0,2"/>

                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                    <TextBlock Text="From: " Foreground="#88bbbb" FontFamily="Consolas"
                               FontSize="12" VerticalAlignment="Center"/>
                    <DatePicker x:Name="dateFrom" FontSize="11" Width="130"
                                Background="#0d2020" Foreground="#000000"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,4">
                    <TextBlock Text="To:   " Foreground="#88bbbb" FontFamily="Consolas"
                               FontSize="12" VerticalAlignment="Center"/>
                    <DatePicker x:Name="dateTo" FontSize="11" Width="130"
                                Background="#0d2020" Foreground="#000000"/>
                </StackPanel>

                <Button x:Name="btnScanJournalsRange" Content="Scan Date Range"
                        Margin="0,0,0,8"
                        Background="#1a3333" Foreground="#00e5ff"
                        FontFamily="Consolas" FontSize="12"
                        BorderBrush="#1a4444" Padding="8,4"
                        HorizontalAlignment="Left"
                        Click="BtnScanJournalsRange_Click"/>

                <Button x:Name="btnClearEarnings" Content="Clear Earnings"
                        Background="#331a1a" Foreground="#ff6666"
                        FontFamily="Consolas" FontSize="12"
                        BorderBrush="#441a1a" Padding="8,4"
                        HorizontalAlignment="Left"
                        Click="BtnClearEarnings_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
